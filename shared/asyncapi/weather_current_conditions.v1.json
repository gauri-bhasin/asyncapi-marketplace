{
  "asyncapi": "2.6.0",
  "info": {
    "title": "Marketplace Weather Feed",
    "version": "1.0.0",
    "description": "Current weather conditions published by weather connector."
  },
  "channels": {
    "marketplace.weather.current_conditions.v1": {
      "description": "Live current weather conditions for configured coordinates.",
      "subscribe": {
        "operationId": "onWeatherCurrentConditions",
        "message": {
          "$ref": "#/components/messages/WeatherCurrentConditionsMessage"
        }
      }
    }
  },
  "components": {
    "messages": {
      "WeatherCurrentConditionsMessage": {
        "name": "WeatherCurrentConditionsMessage",
        "title": "Weather Current Conditions",
        "payload": {
          "$ref": "#/components/schemas/EventEnvelopeWeather"
        },
        "examples": [
          {
            "name": "sample",
            "payload": {
              "event_id": "7da95d39-c5c6-46ac-92ce-fe2703fbd5db",
              "ts": "2026-02-23T14:00:00Z",
              "source": "open-meteo",
              "topic": "marketplace.weather.current_conditions.v1",
              "tags": {
                "geo": "52.52,13.41",
                "entity": "weather"
              },
              "payload": {
                "temperature_c": 3.2,
                "windspeed_kmh": 12.0,
                "winddirection_deg": 87,
                "weathercode": 3,
                "is_day": 1
              }
            }
          }
        ]
      }
    },
    "schemas": {
      "EventEnvelopeWeather": {
        "type": "object",
        "required": ["event_id", "ts", "source", "topic", "tags", "payload"],
        "properties": {
          "event_id": { "type": "string", "format": "uuid" },
          "ts": { "type": "string", "format": "date-time" },
          "source": { "type": "string" },
          "topic": { "type": "string", "const": "marketplace.weather.current_conditions.v1" },
          "tags": {
            "type": "object",
            "properties": {
              "geo": { "type": "string" },
              "entity": { "type": "string" }
            },
            "additionalProperties": true
          },
          "payload": {
            "type": "object",
            "required": ["temperature_c", "windspeed_kmh", "winddirection_deg", "weathercode", "is_day"],
            "properties": {
              "temperature_c": { "type": "number" },
              "windspeed_kmh": { "type": "number" },
              "winddirection_deg": { "type": "number" },
              "weathercode": { "type": "number" },
              "is_day": { "type": "number" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}
